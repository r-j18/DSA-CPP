{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run with I/O",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "g++ -std=gnu++17 -Wall -Wextra -O2${cwd} \"${file}\" -o \"${fileDirname}\\${fileBasenameNoExtension}.exe\" && \"${fileDirname}\\${fileBasenameNoExtension}.exe\" < input.txt > output.txt"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}